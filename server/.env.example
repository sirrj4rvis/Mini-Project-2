# ─── Server Environment Variables — EXAMPLE ──────────────────────────────────
# Copy this to .env and fill in all values before running the server.
# NEVER commit your actual .env file to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get your connection string from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/pricelens?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_char_hex_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_64_char_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Amazon RapidAPI ───────────────────────────────────────────────────────────
# Subscribe at: https://rapidapi.com/search/real-time-amazon-data
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com

# ── eBay Browse API ───────────────────────────────────────────────────────────
# Get at: https://developer.ebay.com → My Apps → Create App
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_ENVIRONMENT=PRODUCTION
EBAY_MARKETPLACE_ID=EBAY-IN

# ── Locale ────────────────────────────────────────────────────────────────────
DEFAULT_COUNTRY=IN
DEFAULT_CURRENCY=INR

# ── Cache (seconds) ───────────────────────────────────────────────────────────
CACHE_TTL_SEARCH=300
CACHE_TTL_PRODUCT=600

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your main password)
# Guide: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── ML Flask Microservice ─────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_TIMEOUT_MS=20000
ML_CACHE_TTL_S=3600

# ── CORS ─────────────────────────────────────────────────────────────────────
# Frontend URL — update to your deployed URL in production
CLIENT_URL=http://localhost:5173
